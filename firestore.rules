rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email == "hugo01freiras@gmail.com" && request.auth.token.email_verified == true);
    }
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'image', 'rating']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.image is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5;
    }
    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'icon']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.icon is string;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(request.resource.data);
      allow update: if isAdmin() && isValidCategory(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
